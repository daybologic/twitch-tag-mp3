=head1 SYNOPSIS

Usage:

	twitch-tag-mp3 --directory <DIR> [--force] [--help] [--jobs <N>] [--json] [--noop] [--recursive] [--verbose] [--version]
	twitch-tag-mp3 -d <DIR> [-f] [-h] [-j <N>] [-J] [-n] [-r] [-v] [-V]

Add MP3 ID3 tags to a file downloaded from Twitch using yt-dlp

=cut

package main;
use strict;
use warnings;

use Daybo::Twitch::Retag;
use Getopt::Long qw(:config no_ignore_case);
use POSIX qw(EXIT_FAILURE EXIT_SUCCESS);
use lib './lib';

=item C<main()>

Parses command-line options via L<Getopt::Long>, constructs a
L<Daybo::Twitch::Retag> instance, and dispatches to C<--version>,
C<--help>, or C<run>.  Returns an exit code suitable for passing to
C<exit>.

=cut

sub main {
	my $startDir;
	my $force = 0;
	my $help = 0;
	my $jobs = 1;
	my $json = 0;
	my $noop = 0;
	my $recursive = 0;
	my $verbose = 0;
	my $version = 0;

	return EXIT_FAILURE unless (GetOptions(
		'directory|d=s' => \$startDir,
		'force|f' => \$force,
		'help|h' => \$help,
		'jobs|j=i' => \$jobs,
		'json|J' => \$json,
		'noop|n' => \$noop,
		'recursive|r' => \$recursive,
		'verbose|v' => \$verbose,
		'version|V' => \$version,
	));

	if ($jobs < 1) {
		print STDERR "Error: --jobs must be at least 1\n";
		return EXIT_FAILURE;
	}

	my $retagger = Daybo::Twitch::Retag->new(
		force => $force,
		jobs => $jobs,
		json => $json,
		noop => $noop,
		recursive => $recursive,
		verbose => $verbose,
	);

	if ($version) {
		print "$Daybo::Twitch::Retag::VERSION\n";
		return EXIT_SUCCESS;
	}

	if ($help) {
		$retagger->usage();
		return EXIT_SUCCESS;
	}

	return $retagger->usage() if (!defined($startDir));
	return $retagger->run($startDir);
}

exit(main()) unless (caller());
